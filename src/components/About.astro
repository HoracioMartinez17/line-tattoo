          <script>
type VideoElementWithSource = HTMLVideoElement & {
  source?: HTMLSourceElement;
};

document.addEventListener("DOMContentLoaded", function () {
  const lazyVideos: NodeListOf<VideoElementWithSource> = document.querySelectorAll(
    "video.lazy-video"
  );
  const playButtons: NodeListOf<HTMLElement> = document.querySelectorAll(".play-button");

  if ("IntersectionObserver" in window) {
    let videoObserver = new IntersectionObserver(function (entries: IntersectionObserverEntry[]) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          const video = entry.target as VideoElementWithSource;
          const source = video.querySelector("source");
          if (source) {
            source.src = source.getAttribute("data-src")!; // Safe access with !
            video.load();
          }
          videoObserver.unobserve(video);
        }
      });
    });

    lazyVideos.forEach(function (video) {
      videoObserver.observe(video);
    });
  }

  playButtons.forEach(function (button) {
    button.addEventListener("click", function () {
      const video = this.previousElementSibling as VideoElementWithSource;
      video.play();
      this.style.display = 'none';
    });
  });

  lazyVideos.forEach(function (video) {
    video.addEventListener("play", function () {
      const button = this.nextElementSibling as HTMLElement;
      button.style.display = 'none';
    });

    video.addEventListener("pause", function () {
      const button = this.nextElementSibling as HTMLElement;
      button.style.display = 'block';
    });

    video.addEventListener("ended", function () {
      const button = this.nextElementSibling as HTMLElement;
      button.style.display = 'block';
    });
  });
});


        </script>
